<p style="color: green"><%= notice %></p>

<% content_for :title, "Documents" %>

<h1>Documents</h1>

<div id="documents">
  <table border="1" width="100%">
    <tr>
      <th>Title</th>
      <th></th>
    </tr>
    <% @documents.each do |document| %>
      <tr>
        <td>
          <%= document.title %>
        </td>
        <td>
          <%= link_to "Delete", document_path(document),
                      data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>        </td>
      </tr>
      <p>
        <%= link_to "Show this document", document %>
      </p>
    <% end %>
  </table>
</div>

<%= link_to "New document", new_document_path %>
